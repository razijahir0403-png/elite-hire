# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas (required in production)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/elite-hire?retryWrites=true&w=majority&appName=Cluster0

# Local fallback — development only (ignored when NODE_ENV=production)
MONGO_URI_FALLBACK=mongodb://127.0.0.1:27017/elite-hire

# Auth — use a long random string in production (openssl rand -base64 48)
JWT_SECRET=your_secure_jwt_secret_here

# CORS — frontend URL(s) allowed to call this API
# Render: set to your Vercel URL after first deploy
CLIENT_URL=https://your-app.vercel.app
# Optional: comma-separated extra origins (preview URLs, custom domains)
CLIENT_URLS=

# Allow any *.vercel.app origin (production + preview deploys)
CORS_ALLOW_VERCEL=true

# Startup
# Set to false after first deploy to skip admin/role seed on every restart
SEED_ON_START=true

# Single-server deploy only (serve React build from Express). Leave false for Vercel + Render split.
SERVE_CLIENT=false

# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
